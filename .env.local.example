# Firebase Configuration (optional — app works without it using localStorage)
# Get these from: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# JDoodle API (optional — for Java code execution)
# Sign up at https://www.jdoodle.com/compiler-api
NEXT_PUBLIC_JDOODLE_CLIENT_ID=
NEXT_PUBLIC_JDOODLE_SECRET=

# Gemini AI (optional — enables AI skill extraction, code feedback, chat)
# Get a free API key at: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=
